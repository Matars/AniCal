{
  "manifest_version": 3,
  "name": "Anime Tracker",
  "version": "1.0",
  "description": "Keep track of your favorite anime and manga releases",
  "icons": {
    "16": "media/icons/logo-16.png",
    "32": "media/icons/logo-32.png",
    "48": "media/icons/logo-48.png",
    "96": "media/icons/logo-96.png",
    "128": "media/icons/logo-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "media/icons/logo-16.png",
      "32": "media/icons/logo-32.png",
      "48": "media/icons/logo-48.png"
    }
  },
  "permissions": [
    "storage",
    "https://api.jikan.moe/"
  ]
}
